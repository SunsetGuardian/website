<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">

    <!-- Google tag (gtag.js) -->
    <script
        async
        src="https://www.googletagmanager.com/gtag/js?id=G-ZYKV3XW7SV"
    ></script>

    <script>
        window.dataLayer = window.dataLayer || [];

        function gtag() {
            dataLayer.push(arguments);
        }

        gtag("js", new Date());
        gtag("config", "G-ZYKV3XW7SV");
    </script>

    <title>
        {%- if not title or title == site.name -%}
            {{ site.name }}
        {%- else -%}
            {{ title }} | {{ site.name }}
        {%- endif -%}
    </title>

    <meta
        name="description"
        content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}"
    >

    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- Open Graph link-preview metadata -->
    <meta property="og:locale" content="en_US">

    <meta
        property="og:type"
        content="{% if pageType == 'article' %}article{% else %}website{% endif %}"
    >

    <meta
        property="og:title"
        content="{% if not title or title == site.name %}{{ site.name }}{% else %}{{ title }} | {{ site.name }}{% endif %}"
    >

    <meta
        property="og:description"
        content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}"
    >

    <meta
        property="og:url"
        content="{{ site.url }}{{ page.url }}"
    >

    <meta
        property="og:site_name"
        content="{{ site.name }}"
    >

    <meta
        property="og:image"
        content="{{ site.url }}{% if socialImage %}{{ socialImage }}{% else %}/assets/sunset-guardian-social-card.png{% endif %}"
    >

    <meta
        property="og:image:secure_url"
        content="{{ site.url }}{% if socialImage %}{{ socialImage }}{% else %}/assets/sunset-guardian-social-card.png{% endif %}"
    >

    <meta
        property="og:image:type"
        content="image/png"
    >

    <meta
        property="og:image:width"
        content="1200"
    >

    <meta
        property="og:image:height"
        content="630"
    >

    <meta
        property="og:image:alt"
        content="{% if socialImageAlt %}{{ socialImageAlt }}{% else %}Sunset Guardian mountain sunset logo with the words Practical tools. Clear explanations.{% endif %}"
    >

    {% if pageType == "article" and datePublished %}
        <meta
            property="article:published_time"
            content="{{ datePublished }}"
        >
    {% endif %}

    {% if pageType == "article" and dateModified %}
        <meta
            property="article:modified_time"
            content="{{ dateModified }}"
        >
    {% endif %}

    <!-- X and other large-card preview metadata -->
    <meta
        name="twitter:card"
        content="summary_large_image"
    >

    <meta
        name="twitter:title"
        content="{% if not title or title == site.name %}{{ site.name }}{% else %}{{ title }} | {{ site.name }}{% endif %}"
    >

    <meta
        name="twitter:description"
        content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}"
    >

    <meta
        name="twitter:image"
        content="{{ site.url }}{% if socialImage %}{{ socialImage }}{% else %}/assets/sunset-guardian-social-card.png{% endif %}"
    >

    <meta
        name="twitter:image:alt"
        content="{% if socialImageAlt %}{{ socialImageAlt }}{% else %}Sunset Guardian mountain sunset logo with the words Practical tools. Clear explanations.{% endif %}"
    >

    <!-- Homepage structured data -->
    {% if page.url == "/" %}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "WebSite",
                    "@id": "{{ site.url }}/#website",
                    "url": "{{ site.url }}/",
                    "name": {{ site.name | dump | safe }},
                    "description": {{ site.description | dump | safe }},
                    "publisher": {
                        "@id": "{{ site.url }}/#organization"
                    }
                },
                {
                    "@type": "Organization",
                    "@id": "{{ site.url }}/#organization",
                    "name": {{ site.name | dump | safe }},
                    "url": "{{ site.url }}/",
                    "description": {{ site.description | dump | safe }},
                    "logo": {
                        "@type": "ImageObject",
                        "url": "{{ site.url }}/assets/favicon.svg",
                        "contentUrl": "{{ site.url }}/assets/favicon.svg"
                    }
                }
            ]
        }
        </script>
    {% endif %}

    <!-- Article structured data -->
    {% if pageType == "article" %}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Article",
            "@id": "{{ site.url }}{{ page.url }}#article",
            "url": "{{ site.url }}{{ page.url }}",
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": "{{ site.url }}{{ page.url }}"
            },
            "headline": {{ (listingTitle or title) | dump | safe }},
            "description": {{ (description or site.description) | dump | safe }},
            "image": {
                "@type": "ImageObject",
                "url": "{{ site.url }}{% if socialImage %}{{ socialImage }}{% else %}/assets/sunset-guardian-social-card.png{% endif %}",
                "contentUrl": "{{ site.url }}{% if socialImage %}{{ socialImage }}{% else %}/assets/sunset-guardian-social-card.png{% endif %}",
                "width": 1200,
                "height": 630
            },
            "datePublished": {{ datePublished | dump | safe }},
            "dateModified": {{ (dateModified or datePublished) | dump | safe }},
            "author": {
                "@type": "Organization",
                "name": {{ site.name | dump | safe }},
                "url": "{{ site.url }}/"
            },
            "publisher": {
                "@type": "Organization",
                "name": {{ site.name | dump | safe }},
                "url": "{{ site.url }}/",
                "logo": {
                    "@type": "ImageObject",
                    "url": "{{ site.url }}/assets/favicon.svg",
                    "contentUrl": "{{ site.url }}/assets/favicon.svg"
                }
            }
        }
        </script>
    {% endif %}

    <link rel="stylesheet" href="/assets/site.css">

    <script src="/assets/site.js" defer></script>

    {% if scripts %}
        {% for script in scripts %}
            <script src="{{ script }}" defer></script>
        {% endfor %}
    {% endif %}
</head>

<body>
    <header class="site-header">
        <nav class="site-nav" aria-label="Main navigation">
            <a class="site-brand" href="/">
                <img
                    class="site-logo"
                    src="/assets/favicon.svg"
                    alt=""
                    width="28"
                    height="28"
                    aria-hidden="true"
                >

                <span>{{ site.name }}</span>
            </a>

            <button
                class="menu-toggle"
                type="button"
                aria-expanded="false"
                aria-controls="main-menu"
                aria-label="Open navigation menu"
            >
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="nav-links" id="main-menu">
                {% for item in site.navigation %}
                    <a
                        href="{{ item.url }}"
                        {% if navKey == item.key %}
                            aria-current="page"
                        {% endif %}
                    >
                        {{ item.label }}
                    </a>
                {% endfor %}
            </div>
        </nav>
    </header>

    <main class="site-main" id="main-content">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <p class="site-footer-brand">
            <img
                class="site-logo site-logo-small"
                src="/assets/favicon.svg"
                alt=""
                width="18"
                height="18"
                aria-hidden="true"
            >

            <span>{{ site.name }}</span>
        </p>

        <p>
            <a class="inline-link" href="/privacy/">
                Privacy Policy
            </a>

            <span aria-hidden="true"> · </span>

            <a class="inline-link" href="/disclaimer/">
                Financial Disclaimer
            </a>
        </p>
    </footer>
</body>
</html>
