---
layout: layouts/base.njk
title: Compound Interest Calculator
description: Estimate how a starting balance and monthly contributions can grow over time.
navKey: tools
tags:
  - tools
scripts:
  - /assets/tools/compound-interest.js

---

<div class="calculator-page">
    <section class="page-hero page-hero-compact">
        <p class="eyebrow">Growth calculator</p>

        <h1>Compound Interest Calculator</h1>

        <p class="hero-copy">
            Estimate how a starting balance and monthly contributions
            can grow over time.
        </p>
    </section>

    <section class="calculator-card">
        <div class="calculator-input-grid">
            <div class="calculator-field">
                <label for="starting-balance">
                    Starting balance
                </label>

                <input
                    id="starting-balance"
                    type="number"
                    min="0"
                    step="100"
                    value="10000"
                    inputmode="decimal"
                >
            </div>

            <div class="calculator-field">
                <label for="monthly-contribution">
                    Monthly contribution
                </label>

                <input
                    id="monthly-contribution"
                    type="number"
                    min="0"
                    step="25"
                    value="250"
                    inputmode="decimal"
                >
            </div>

            <div class="calculator-field">
                <label for="annual-rate">
                    Annual interest rate
                </label>

                <div class="calculator-input-suffix">
                    <input
                        id="annual-rate"
                        type="number"
                        min="0"
                        step="0.01"
                        value="7"
                        inputmode="decimal"
                    >

                    <span aria-hidden="true">%</span>
                </div>
            </div>

            <div class="calculator-field">
                <label for="investment-years">
                    Years
                </label>

                <input
                    id="investment-years"
                    type="number"
                    min="1"
                    step="1"
                    value="20"
                    inputmode="numeric"
                >
            </div>
        </div>

        <div
            class="calculator-results"
            aria-live="polite"
        >
            <div class="calculator-result">
                <span class="calculator-result-label">
                    Ending balance
                </span>

                <strong
                    class="calculator-result-value"
                    id="ending-balance"
                >
                    $0
                </strong>
            </div>

            <div class="calculator-result">
                <span class="calculator-result-label">
                    Total contributed
                </span>

                <strong
                    class="calculator-result-value"
                    id="total-contributed"
                >
                    $0
                </strong>
            </div>

            <div class="calculator-result">
                <span class="calculator-result-label">
                    Interest earned
                </span>

                <strong
                    class="calculator-result-value"
                    id="interest-earned"
                >
                    $0
                </strong>
            </div>
        </div>

        <div class="calculator-explanation">
            <h2>How this calculator works</h2>

            <p>
                The calculation assumes monthly compounding and
                contributions made at the end of each month.
            </p>

            <p>
                The estimated ending balance includes the growth of the
                starting balance plus the growth of each monthly contribution.
            </p>
        </div>
    </section>

    {% include "components/related-guide.njk" %}

    <p class="tool-disclaimer">
        For educational purposes only. Results are estimates and do not
        include taxes, fees, inflation, or changing rates of return.
    </p>
</div>
