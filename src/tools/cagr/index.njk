---
layout: layouts/base.njk
title: CAGR Calculator
description: Calculate compound annual growth rate and total investment return.
navKey: tools
tags:
  - tools
scripts:
  - /assets/tools/cagr.js
---

<div class="calculator-page">
    <section class="page-hero page-hero-compact">
        <p class="eyebrow">Growth calculator</p>

        <h1>🌅 CAGR Calculator</h1>

        <p class="hero-copy">
            Find an investment's compound annual growth rate
            and total return.
        </p>
    </section>

    <section
        class="calculator-card"
        data-cagr-calculator
        aria-label="CAGR calculator"
    >
        <div class="calculator-input-grid">
            <div class="calculator-field">
                <label for="startingValue">
                    Starting value
                </label>

                <input
                    id="startingValue"
                    type="number"
                    min="0.01"
                    step="any"
                    value="10000"
                    inputmode="decimal"
                >
            </div>

            <div class="calculator-field">
                <label for="endingValue">
                    Ending value
                </label>

                <input
                    id="endingValue"
                    type="number"
                    min="0.01"
                    step="any"
                    value="15000"
                    inputmode="decimal"
                >
            </div>

            <div class="calculator-field">
                <label for="years">
                    Years held
                </label>

                <input
                    id="years"
                    type="number"
                    min="0.01"
                    step="any"
                    value="5"
                    inputmode="decimal"
                >
            </div>
        </div>

        <p
            class="calculator-error"
            id="calculatorError"
            role="alert"
        ></p>

        <div
            class="calculator-results"
            aria-live="polite"
        >
            <div class="calculator-result">
                <span class="calculator-result-label">
                    CAGR
                </span>

                <strong
                    class="calculator-result-value"
                    id="cagr"
                >
                    —
                </strong>
            </div>

            <div class="calculator-result">
                <span class="calculator-result-label">
                    Total return
                </span>

                <strong
                    class="calculator-result-value"
                    id="totalReturn"
                >
                    —
                </strong>
            </div>
        </div>

        <div class="calculator-explanation">
            <h2>What is CAGR?</h2>

            <p>
                Compound annual growth rate shows the constant yearly rate
                that would turn the starting value into the ending value over
                the selected period.
            </p>

            <div class="formula-grid formula-grid-single">
                <div class="formula-card">
                    <span>Formula</span>

                    <code>
                        (Ending value ÷ Starting value)^(1 ÷ Years) − 1
                    </code>
                </div>
            </div>
        </div>
    </section>

    <p class="tool-disclaimer">
        For educational purposes only. Results do not include deposits,
        withdrawals, taxes, fees, or inflation.
    </p>
</div>
{% include "components/related-guide.njk" %}
